{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Eternum",
  "colors": {
    "primary": "#60A5FA",
    "light": "#93C5FD",
    "dark": "#2563EB"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "User guides",
            "pages": [
              "guides/vault",
              "guides/trusted-contacts",
              "guides/beneficiaries",
              "guides/check-ins",
              "guides/billing"
            ]
          },
          {
            "group": "Recovery",
            "pages": [
              "recovery/overview",
              "recovery/trusted-contact-release",
              "recovery/beneficiary-claim"
            ]
          }
        ]
      },
      {
        "tab": "Security",
        "groups": [
          {
            "group": "Security model",
            "pages": [
              "security/zero-knowledge-model",
              "security/key-management",
              "security/recovery-shares"
            ]
          }
        ]
      },
      {
        "tab": "Operators",
        "groups": [
          {
            "group": "Operations",
            "pages": [
              "operators/deployment",
              "operators/admin-pipeline",
              "operators/environment"
            ]
          }
        ]
      },
      {
        "tab": "ChainLens",
        "groups": [
          {
            "group": "Start here",
            "pages": [
              "chainlens/overview",
              "chainlens/quickstart"
            ]
          },
          {
            "group": "Product guide",
            "pages": [
              "chainlens/concepts",
              "chainlens/configuration",
              "chainlens/workflows",
              "chainlens/api-reference"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://eternum-staging.frostnova.moe",
          "icon": "external-link"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/Archive-Circle/eternum",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Archive-Circle/eternum"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://eternum-staging.frostnova.moe"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Archive-Circle/eternum"
    }
  }
}
